# Micro Budget (mobile) — copy to .env and fill in. .env is gitignored.
# EXPO_PUBLIC_* vars are inlined into the client bundle. All of these are
# client-safe keys (public by design); the Supabase DB password is NOT here.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx

# PostHog analytics (EU Cloud)
EXPO_PUBLIC_POSTHOG_KEY=phc_xxxxxxxx
EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
