{
  "expo": {
    "name": "Micro Budget",
    "slug": "micro-budget",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "microbudget",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.otepskiee.microbudget",
      "icon": "./assets/expo.icon",
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": ["location", "fetch"]
      }
    },
    "android": {
      "package": "com.otepskiee.microbudget",
      "adaptiveIcon": {
        "backgroundColor": "#E3E5DE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#E3E5DE",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      "expo-sqlite",
      "expo-secure-store",
      "expo-font",
      "expo-localization",
      ["expo-notifications", { "color": "#211C15" }],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Micro Budget uses your location during a trip to retrace your day and recover forgotten expenses.",
          "locationAlwaysAndWhenInUsePermission": "Micro Budget uses your location during a trip to retrace your day and recover forgotten expenses.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Micro Budget uses the camera to scan your receipts."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
