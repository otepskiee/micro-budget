# Micro Budget — Supabase config. Copy to .env.local and fill in real values.
# .env.local is gitignored. NEVER commit real keys.

# Client-safe — ships in the app, protected by Row-Level Security:
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx

# Admin / migrations only — NEVER put in client code or commit.
# Prefer `supabase link` (it prompts for the password) over storing it here.
# SUPABASE_DB_PASSWORD=
